{
  "name": "letopis-node",
  "version": "0.1.0",
  "description": "Node.js / TypeScript SDK for the Letopis history-management service",
  "license": "Apache-2.0",
  "author": "Max Trifonov <mp.trifonov@gmail.com>",
  "homepage": "https://letopis.tech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/max-trifonov/letopis-node.git"
  },
  "bugs": {
    "url": "https://github.com/max-trifonov/letopis-node/issues"
  },
  "keywords": ["letopis", "history", "audit-log", "nestjs"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./nestjs": {
      "import": "./dist/nestjs/index.js",
      "types": "./dist/nestjs/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/fake.js",
      "types": "./dist/testing/fake.d.ts"
    }
  },
  "files": ["dist", "NOTICE"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "jest": "^29.0.0",
    "reflect-metadata": "^0.2.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10",
    "@nestjs/core": ">=10",
    "reflect-metadata": ">=0.1"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": { "optional": true },
    "@nestjs/core": { "optional": true },
    "reflect-metadata": { "optional": true }
  }
}
